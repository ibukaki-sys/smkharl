<!DOCTYPE html>
<html lang="ms">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: transparent; }

  .aero-wrap {
    background: linear-gradient(160deg, #1a3a6b 0%, #0d1f42 40%, #0a1628 100%);
    border-radius: 18px;
    padding: 20px 16px 18px;
    position: relative;
    overflow: hidden;
  }
  .aero-wrap::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 50%;
    background: linear-gradient(180deg, rgba(255,255,255,0.07) 0%, transparent 100%);
    pointer-events: none; border-radius: 18px 18px 0 0;
  }
  .aero-orb { position: absolute; border-radius: 50%; pointer-events: none; }
  .orb1 { width: 180px; height: 180px; background: radial-gradient(circle, rgba(80,140,255,0.18) 0%, transparent 70%); top: -40px; right: -20px; }
  .orb2 { width: 120px; height: 120px; background: radial-gradient(circle, rgba(100,200,255,0.12) 0%, transparent 70%); bottom: 20px; left: -10px; }

  .aero-badge {
    display: inline-flex; align-items: center; gap: 5px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.18);
    border-radius: 20px; padding: 3px 10px 3px 6px;
    font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.75);
    letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 8px;
  }
  .aero-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #4fc3f7; flex-shrink: 0; }
  .aero-title { font-size: 20px; font-weight: 700; color: #fff; line-height: 1.15; letter-spacing: -0.3px; }
  .aero-sub { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 3px; }
  .aero-divider { height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent); margin: 14px 0; }

  .aero-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 9px; }

  .aero-card {
    background: linear-gradient(145deg, rgba(255,255,255,0.13) 0%, rgba(255,255,255,0.05) 100%);
    border: 1px solid rgba(255,255,255,0.18); border-radius: 14px;
    padding: 13px 11px 11px; text-decoration: none;
    display: flex; flex-direction: column; gap: 9px;
    min-height: 108px; position: relative; overflow: hidden;
    transition: background 0.2s, border-color 0.2s;
    -webkit-tap-highlight-color: transparent;
  }
  .aero-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 40%;
    background: linear-gradient(180deg, rgba(255,255,255,0.09) 0%, transparent 100%);
    border-radius: 14px 14px 0 0; pointer-events: none;
  }
  .aero-card:active { background: linear-gradient(145deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.03) 100%); }
  .aero-card-top { display: flex; align-items: flex-start; justify-content: space-between; }
  .aero-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 19px; flex-shrink: 0; border: 1px solid rgba(255,255,255,0.2);
  }
  .aero-ext { font-size: 13px; color: rgba(255,255,255,0.3); }
  .aero-label { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.92); line-height: 1.35; }
  .aero-url { font-size: 10px; color: rgba(255,255,255,0.35); margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .aero-wide { grid-column: 1 / -1; flex-direction: row; align-items: center; gap: 13px; min-height: auto; padding: 12px 14px; }
  .aero-wide .aero-body { flex: 1; min-width: 0; }
  .aero-wide .aero-ext { margin-left: auto; flex-shrink: 0; }
  .aero-footer { margin-top: 14px; text-align: center; font-size: 10px; color: rgba(255,255,255,0.22); letter-spacing: 0.06em; }
</style>
</head>
<body>

<div class="aero-wrap">
  <div class="aero-orb orb1"></div>
  <div class="aero-orb orb2"></div>

  <div style="margin-bottom:16px;position:relative;">
    <div class="aero-badge"><span class="aero-badge-dot"></span>SMK Haji Abdul Rahman Limbong</div>
    <div class="aero-title">Sistem Dalam Talian</div>
    <div class="aero-sub">5 aplikasi sekolah &mdash; satu tempat</div>
  </div>

  <div class="aero-divider"></div>

  <div class="aero-grid">

    <a class="aero-card" href="https://limbonghadir.netlify.app" target="_blank">
      <div class="aero-card-top">
        <div class="aero-icon" style="background:linear-gradient(145deg,rgba(29,158,117,0.5),rgba(15,110,86,0.3));border-color:rgba(93,202,165,0.35);color:#9fe1cb;"><i class="ti ti-map-pin-check"></i></div>
        <span class="aero-ext"><i class="ti ti-arrow-up-right"></i></span>
      </div>
      <div>
        <div class="aero-label">eKehadiran Tok Limbong</div>
        <div class="aero-url">limbonghadir.netlify.app</div>
      </div>
    </a>

    <a class="aero-card" href="https://keberadaanguru.netlify.app" target="_blank">
      <div class="aero-card-top">
        <div class="aero-icon" style="background:linear-gradient(145deg,rgba(127,119,221,0.5),rgba(83,74,183,0.3));border-color:rgba(175,169,236,0.35);color:#cecbf6;"><i class="ti ti-user-check"></i></div>
        <span class="aero-ext"><i class="ti ti-arrow-up-right"></i></span>
      </div>
      <div>
        <div class="aero-label">Keberadaan Guru</div>
        <div class="aero-url">keberadaanguru.netlify.app</div>
      </div>
    </a>

    <a class="aero-card" href="https://ibukaki-sys.github.io/sistem-kehadiran" target="_blank">
      <div class="aero-card-top">
        <div class="aero-icon" style="background:linear-gradient(145deg,rgba(55,138,221,0.5),rgba(24,95,165,0.3));border-color:rgba(133,183,235,0.35);color:#b5d4f4;"><i class="ti ti-clipboard-list"></i></div>
        <span class="aero-ext"><i class="ti ti-arrow-up-right"></i></span>
      </div>
      <div>
        <div class="aero-label">Kehadiran Program</div>
        <div class="aero-url">ibukaki-sys.github.io</div>
      </div>
    </a>

    <a class="aero-card" href="https://bukukawalan.netlify.app" target="_blank">
      <div class="aero-card-top">
        <div class="aero-icon" style="background:linear-gradient(145deg,rgba(186,117,23,0.5),rgba(133,79,11,0.3));border-color:rgba(239,159,39,0.35);color:#fac775;"><i class="ti ti-book-2"></i></div>
        <span class="aero-ext"><i class="ti ti-arrow-up-right"></i></span>
      </div>
      <div>
        <div class="aero-label">Buku Kawalan Kelas</div>
        <div class="aero-url">bukukawalan.netlify.app</div>
      </div>
    </a>

    <a class="aero-card aero-wide" href="https://biliktempah.netlify.app" target="_blank">
      <div class="aero-icon" style="background:linear-gradient(145deg,rgba(216,90,48,0.5),rgba(153,60,29,0.3));border-color:rgba(240,153,123,0.35);color:#f5c4b3;"><i class="ti ti-door"></i></div>
      <div class="aero-body">
        <div class="aero-label">Sistem Tempahan Bilik</div>
        <div class="aero-url">biliktempah.netlify.app</div>
      </div>
      <span class="aero-ext"><i class="ti ti-arrow-up-right"></i></span>
    </a>

  </div>

  <div class="aero-footer">Kuala Terengganu &middot; 2025</div>
</div>

</body>
</html>
